{
  "$defs": {
    "BaselineCellSnapshot": {
      "properties": {
        "key": {
          "$ref": "#/$defs/CellKey"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "duration_ms": {
          "default": 0.0,
          "title": "Duration Ms",
          "type": "number"
        },
        "metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Metrics",
          "type": "object"
        }
      },
      "required": [
        "key",
        "passed"
      ],
      "title": "BaselineCellSnapshot",
      "type": "object"
    },
    "BaselineOverall": {
      "properties": {
        "pass_rate": {
          "title": "Pass Rate",
          "type": "number"
        },
        "duration_ms_mean": {
          "default": 0.0,
          "title": "Duration Ms Mean",
          "type": "number"
        },
        "cell_count": {
          "title": "Cell Count",
          "type": "integer"
        },
        "metrics": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Metrics",
          "type": "object"
        }
      },
      "required": [
        "pass_rate",
        "cell_count"
      ],
      "title": "BaselineOverall",
      "type": "object"
    },
    "CellKey": {
      "description": "Stable identity for a matrix cell (cases \u00d7 profiles \u00d7 models).",
      "properties": {
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "profile_id": {
          "title": "Profile Id",
          "type": "string"
        },
        "model_id": {
          "title": "Model Id",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "profile_id",
        "model_id"
      ],
      "title": "CellKey",
      "type": "object"
    },
    "ReportFingerprint": {
      "properties": {
        "matrix_name": {
          "title": "Matrix Name",
          "type": "string"
        },
        "profile_ids": {
          "items": {
            "type": "string"
          },
          "title": "Profile Ids",
          "type": "array"
        },
        "case_ids": {
          "items": {
            "type": "string"
          },
          "title": "Case Ids",
          "type": "array"
        }
      },
      "required": [
        "matrix_name",
        "profile_ids",
        "case_ids"
      ],
      "title": "ReportFingerprint",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "profile_id": {
      "title": "Profile Id",
      "type": "string"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "source_report_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Report Path"
    },
    "fingerprint": {
      "$ref": "#/$defs/ReportFingerprint"
    },
    "overall": {
      "$ref": "#/$defs/BaselineOverall"
    },
    "cells": {
      "additionalProperties": {
        "$ref": "#/$defs/BaselineCellSnapshot"
      },
      "title": "Cells",
      "type": "object"
    }
  },
  "required": [
    "profile_id",
    "updated_at",
    "fingerprint",
    "overall"
  ],
  "title": "Baseline",
  "type": "object"
}
