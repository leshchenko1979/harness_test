{
  "$defs": {
    "AttemptRecord": {
      "properties": {
        "attempt_index": {
          "title": "Attempt Index",
          "type": "integer"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/RunArtifact"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "duration_ms": {
          "default": 0.0,
          "title": "Duration Ms",
          "type": "number"
        }
      },
      "required": [
        "attempt_index",
        "passed"
      ],
      "title": "AttemptRecord",
      "type": "object"
    },
    "CellKey": {
      "description": "Stable identity for a matrix cell (cases \u00d7 profiles \u00d7 models).",
      "properties": {
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "profile_id": {
          "title": "Profile Id",
          "type": "string"
        },
        "model_id": {
          "title": "Model Id",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "profile_id",
        "model_id"
      ],
      "title": "CellKey",
      "type": "object"
    },
    "Message": {
      "properties": {
        "role": {
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ],
          "title": "Role",
          "type": "string"
        },
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "tool_call_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Id"
        }
      },
      "required": [
        "role"
      ],
      "title": "Message",
      "type": "object"
    },
    "RunArtifact": {
      "description": "Agent-shaped output from a runtime (Phase 2+ executor).",
      "properties": {
        "messages": {
          "items": {
            "$ref": "#/$defs/Message"
          },
          "title": "Messages",
          "type": "array"
        },
        "metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Metrics",
          "type": "object"
        },
        "tools_called": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Tools Called",
          "type": "object"
        },
        "evaluators": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              }
            ]
          },
          "title": "Evaluators",
          "type": "object"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "title": "RunArtifact",
      "type": "object"
    }
  },
  "properties": {
    "key": {
      "$ref": "#/$defs/CellKey"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "attempts": {
      "items": {
        "$ref": "#/$defs/AttemptRecord"
      },
      "title": "Attempts",
      "type": "array"
    },
    "flaky_suspect": {
      "default": false,
      "title": "Flaky Suspect",
      "type": "boolean"
    },
    "duration_ms": {
      "default": 0.0,
      "title": "Duration Ms",
      "type": "number"
    },
    "metrics": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "string"
          },
          {
            "type": "boolean"
          }
        ]
      },
      "title": "Metrics",
      "type": "object"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    }
  },
  "required": [
    "key",
    "passed"
  ],
  "title": "CellResult",
  "type": "object"
}
