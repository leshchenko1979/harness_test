{
  "$defs": {
    "AttemptRecord": {
      "properties": {
        "attempt_index": {
          "title": "Attempt Index",
          "type": "integer"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/RunArtifact"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "duration_ms": {
          "default": 0.0,
          "title": "Duration Ms",
          "type": "number"
        }
      },
      "required": [
        "attempt_index",
        "passed"
      ],
      "title": "AttemptRecord",
      "type": "object"
    },
    "CellKey": {
      "description": "Stable identity for a matrix cell (cases \u00d7 profiles \u00d7 models).",
      "properties": {
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "profile_id": {
          "title": "Profile Id",
          "type": "string"
        },
        "model_id": {
          "title": "Model Id",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "profile_id",
        "model_id"
      ],
      "title": "CellKey",
      "type": "object"
    },
    "CellResult": {
      "properties": {
        "key": {
          "$ref": "#/$defs/CellKey"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "attempts": {
          "items": {
            "$ref": "#/$defs/AttemptRecord"
          },
          "title": "Attempts",
          "type": "array"
        },
        "flaky_suspect": {
          "default": false,
          "title": "Flaky Suspect",
          "type": "boolean"
        },
        "duration_ms": {
          "default": 0.0,
          "title": "Duration Ms",
          "type": "number"
        },
        "metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Metrics",
          "type": "object"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "key",
        "passed"
      ],
      "title": "CellResult",
      "type": "object"
    },
    "Message": {
      "properties": {
        "role": {
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ],
          "title": "Role",
          "type": "string"
        },
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "tool_call_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Id"
        }
      },
      "required": [
        "role"
      ],
      "title": "Message",
      "type": "object"
    },
    "ReportFingerprint": {
      "properties": {
        "matrix_name": {
          "title": "Matrix Name",
          "type": "string"
        },
        "profile_ids": {
          "items": {
            "type": "string"
          },
          "title": "Profile Ids",
          "type": "array"
        },
        "case_ids": {
          "items": {
            "type": "string"
          },
          "title": "Case Ids",
          "type": "array"
        }
      },
      "required": [
        "matrix_name",
        "profile_ids",
        "case_ids"
      ],
      "title": "ReportFingerprint",
      "type": "object"
    },
    "ReportOverall": {
      "properties": {
        "pass_rate": {
          "title": "Pass Rate",
          "type": "number"
        },
        "duration_ms_mean": {
          "default": 0.0,
          "title": "Duration Ms Mean",
          "type": "number"
        },
        "cell_count": {
          "title": "Cell Count",
          "type": "integer"
        },
        "metrics": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Metrics",
          "type": "object"
        }
      },
      "required": [
        "pass_rate",
        "cell_count"
      ],
      "title": "ReportOverall",
      "type": "object"
    },
    "RunArtifact": {
      "description": "Agent-shaped output from a runtime (Phase 2+ executor).",
      "properties": {
        "messages": {
          "items": {
            "$ref": "#/$defs/Message"
          },
          "title": "Messages",
          "type": "array"
        },
        "metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Metrics",
          "type": "object"
        },
        "evaluators": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              }
            ]
          },
          "title": "Evaluators",
          "type": "object"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "title": "RunArtifact",
      "type": "object"
    },
    "SamplingMeta": {
      "properties": {
        "sampled": {
          "default": false,
          "title": "Sampled",
          "type": "boolean"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "max_cells": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Cells"
        },
        "share": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Share"
        },
        "always_include_tags": {
          "items": {
            "type": "string"
          },
          "title": "Always Include Tags",
          "type": "array"
        },
        "planned_cells": {
          "default": 0,
          "title": "Planned Cells",
          "type": "integer"
        },
        "executed_cells": {
          "default": 0,
          "title": "Executed Cells",
          "type": "integer"
        },
        "skipped_cells": {
          "items": {
            "$ref": "#/$defs/CellKey"
          },
          "title": "Skipped Cells",
          "type": "array"
        }
      },
      "title": "SamplingMeta",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "commit_sha": {
      "default": "local",
      "title": "Commit Sha",
      "type": "string"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    },
    "matrix_path": {
      "title": "Matrix Path",
      "type": "string"
    },
    "matrix_name": {
      "title": "Matrix Name",
      "type": "string"
    },
    "fingerprint": {
      "$ref": "#/$defs/ReportFingerprint"
    },
    "sampling": {
      "$ref": "#/$defs/SamplingMeta"
    },
    "run_max_retries": {
      "default": 0,
      "title": "Run Max Retries",
      "type": "integer"
    },
    "cells": {
      "items": {
        "$ref": "#/$defs/CellResult"
      },
      "title": "Cells",
      "type": "array"
    },
    "overall": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReportOverall"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "timestamp",
    "matrix_path",
    "matrix_name",
    "fingerprint"
  ],
  "title": "MatrixReport",
  "type": "object"
}
