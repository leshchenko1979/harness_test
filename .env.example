# Required for LLM eval runs (matches api_key_env in evals/models/minimax-m2.7.yaml)
MINIMAX_API_KEY=your-minimax-api-key

# Optional per-preset overrides (prefix derived from api_key_env):
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# Optional: Logfire (requires VPN from some locations)
LOGFIRE_TOKEN=

# Gategrid artifact dir (default: .gategrid/)
# GATEGRID_HOME=

# Default eval tree for dogfood matrices
# GATEGRID_EVAL_ROOT=evals

# Set by GitHub Actions
# GITHUB_SHA=
